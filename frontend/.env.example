# Frontend environment variables for the admin SPA.
#
# Vite exposes ONLY variables prefixed with `VITE_` to client code, and it
# bakes them into the built bundle at BUILD TIME. Changing them requires
# rebuilding the app (e.g. `c2a rebuild app --app admin`).
#
# Copy this file to `.env.development` for local development, or set these
# as `build.env` entries on the kpack Image for production.

# Absolute base URL for the admin-api backend. NO trailing slash.
# - Local dev: leave unset (empty) so api.ts falls back to same-origin and
#   Vite's dev proxy forwards /api → http://localhost:54321.
# - Production: point at the deployed admin-api host.
VITE_ADMIN_API_URL=https://admin-api.control.apps.clue2.app
